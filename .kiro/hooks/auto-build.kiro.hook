{
  "enabled": false,
  "name": "Auto Build",
  "description": "Automatically runs npm run build when any TypeScript source file or manifest is edited",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "src/**/*.ts",
      "manifest.json"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npm run build"
  }
}