{
  "enabled": true,
  "name": "Auto Commit",
  "description": "Automatically stages and commits all changes when the agent finishes working",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "git add -A && git commit -m \"auto: update from agent session\""
  }
}